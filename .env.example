# ================================
# Database
# ================================
DATABASE_URL=postgresql://meetmate:meetmate@postgres:5432/meetmate

# ================================
# Redis
# ================================
REDIS_URL=redis://redis:6379

# ================================
# MinIO (Local Object Storage)
# ================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=meetmate-recordings
MINIO_SECURE=false

# ================================
# Email (pilih salah satu)
# ================================
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false

# ================================
# Auth
# ================================
JWT_SECRET_KEY=your_super_secret_key_here
JWT_EXPIRE_MINUTES=1440
CHECKIN_TOKEN_EXPIRE_HOURS=24

# ================================
# Language Model (LLM) Provider
# ================================
# Pilihan: 'openai' atau 'ollama'
LLM_PROVIDER=openai

# Jika LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Jika LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# ================================
# Whisper (Transkripsi)
# ================================
WHISPER_MODEL=large-v3

# ================================
# File Upload
# ================================
MAX_UPLOAD_SIZE_MB=200
MAX_AUDIO_DURATION_HOURS=2
ALLOWED_AUDIO_FORMATS=mp3,mp4,wav,m4a

# ================================
# App
# ================================
APP_ENV=development
APP_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# HuggingFace Token untuk model pyannote (Diarization)
HF_TOKEN=hf_your_huggingface_token_here
